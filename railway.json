{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build",
    "watchPatterns": [
      "api/**",
      "src/**",
      "public/**",
      "index.html",
      "package.json",
      "postcss.config.mjs",
      "server.js",
      "utils/**",
      "vite.config.js"
    ]
  },
  "deploy": {
    "startCommand": "node server.js",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "runtime": "V2"
  }
}
